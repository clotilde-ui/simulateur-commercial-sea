# Variables d'environnement pour l'envoi des invitations via Brevo (fonction /api/invite).
# À renseigner dans Vercel : Settings → Environment Variables (NE PAS committer de vraies clés).

# Clé API Brevo (v3) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Email expéditeur — doit être un expéditeur vérifié dans Brevo
BREVO_SENDER_EMAIL=

# Nom expéditeur (optionnel)
BREVO_SENDER_NAME=Sonate

# Store partagé (invitations + comptes) — Vercel KV ou Upstash Redis.
# Créez un store « KV » dans Vercel (Storage → KV) : ces 2 variables sont alors
# fournies automatiquement. Sinon, renseignez les équivalents Upstash.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (équivalents Upstash si vous n'utilisez pas Vercel KV)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
